# Copy this file to .env and fill in your secrets.
# Never commit .env to version control.
# When adding new variables, update src/env.js accordingly.

# ── Authentication (NextAuth v5) ─────────────────────────────────────────────
# Generate with: npx auth secret  OR  openssl rand -base64 32
AUTH_SECRET=""

# Discord OAuth — https://discord.com/developers/applications
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# ── Amadeus Travel API ────────────────────────────────────────────────────────
# Register free at: https://developers.amadeus.com/register
# Without these the app shows demo/mock hotel data.
AMADEUS_CLIENT_ID=""
AMADEUS_CLIENT_SECRET=""

# ── Runtime ──────────────────────────────────────────────────────────────────
# Railway injects PORT automatically — only override locally if needed.
# PORT=3000
NODE_ENV="development"
